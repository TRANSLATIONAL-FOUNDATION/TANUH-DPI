{
  "uid": "tanuh-platform-overview",
  "title": "Platform Overview",
  "description": "Executive and operational homepage. Service health at a glance. Opens first during incidents.",
  "tags": ["overview", "tanuh-dpi"],
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "title": "Platform Overview", "url": "/d/tanuh-platform-overview", "type": "link", "icon": "dashboard", "tooltip": "Platform Overview", "targetBlank": false, "tags": [] },
    { "title": "Service Operations", "url": "/d/tanuh-service-ops", "type": "link", "icon": "dashboard", "tooltip": "Service Operations", "targetBlank": false, "tags": [] },
    { "title": "Worker Pipeline", "url": "/d/tanuh-worker-pipeline", "type": "link", "icon": "dashboard", "tooltip": "Worker Pipeline", "targetBlank": false, "tags": [] },
    { "title": "Infrastructure", "url": "/d/tanuh-infra-reliability", "type": "link", "icon": "dashboard", "tooltip": "Infrastructure & Reliability", "targetBlank": false, "tags": [] },
    { "title": "Alerts", "url": "/d/tanuh-alerts-incidents", "type": "link", "icon": "dashboard", "tooltip": "Alerts & Incidents", "targetBlank": false, "tags": [] },
    { "title": "Log Explorer", "url": "/d/tanuh-log-explorer", "type": "link", "icon": "dashboard", "tooltip": "Log Explorer", "targetBlank": false, "tags": [] }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "expr": "ALERTS{alertstate=\"firing\"}",
        "hide": false,
        "iconColor": "#E53E3E",
        "name": "Firing Alerts",
        "step": "60s",
        "titleFormat": "{{alertname}} — {{severity}}",
        "textFormat": "{{service}}"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "options": [
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": true,  "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" }
        ],
        "current": { "selected": true, "text": "5m", "value": "5m" },
        "hide": 0,
        "query": "1m,5m,15m",
        "auto": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "━━━━━━  HERO BAND  ━━━━━━",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "text",
      "title": "",
      "description": "Platform identity banner. Status badge color reflects min(up) across all 5 DPI services.",
      "gridPos": { "x": 0, "y": 1, "w": 16, "h": 3 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;align-items:center;height:100%;padding:8px 16px;background:#1a1a2e;border-radius:4px\"><div style=\"font-size:24px;font-weight:700;color:#ffffff;letter-spacing:1px\">TANUH-DPI</div><div style=\"font-size:13px;color:#a0aec0;margin-left:16px\">Healthcare Document Processing Platform &nbsp;·&nbsp; Production &nbsp;·&nbsp; VM: 34.14.179.41</div></div>"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Platform Status",
      "description": "OPERATIONAL when all 5 DPI services are up. SERVICE DEGRADED when any service is down.",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "min(up{job=~\"pdf2abdm|pdf2nhcx|privacy_filter|forgensic|session_logger\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#E53E3E" },
              { "value": 1, "color": "#3CB371" }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "⚠ SERVICE DEGRADED" }, "1": { "text": "● OPERATIONAL" } } }
          ],
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Health Score",
      "description": "Composite 0–100 score: Service Availability (35%) + Error Rate (25%) + Queue Health (15%) + Alert Health (15%) + Infrastructure (10%).",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "dpi:platform_health_score",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#E53E3E" },
              { "value": 60, "color": "#FFA500" },
              { "value": 80, "color": "#4299E1" },
              { "value": 95, "color": "#3CB371" }
            ]
          },
          "mappings": [
            { "type": "range", "options": { "from": 95, "to": 100, "result": { "text": "✦ EXCELLENT" } } },
            { "type": "range", "options": { "from": 80, "to": 94.9, "result": { "text": "● GOOD" } } },
            { "type": "range", "options": { "from": 60, "to": 79.9, "result": { "text": "▲ DEGRADED" } } },
            { "type": "range", "options": { "from": 0, "to": 59.9, "result": { "text": "✖ CRITICAL" } } }
          ],
          "color": { "mode": "thresholds" },
          "unit": "short",
          "min": 0,
          "max": 100
        }
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "━━━━━━  BUSINESS ACTIVITY  ━━━━━━",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Clinical Records",
      "description": "ABDM clinical documents processed in the selected time range. Measures real-world throughput for healthcare record extraction.",
      "gridPos": { "x": 0, "y": 5, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(dpi_documents_processed_total{service=\"pdf2abdm\"}[$__range]))", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#4299E1", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#4299E1" }] }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Insurance Claims",
      "description": "NHCX insurance policy documents processed in the selected time range.",
      "gridPos": { "x": 6, "y": 5, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(dpi_documents_processed_total{service=\"pdf2nhcx\"}[$__range]))", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#805AD5", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#805AD5" }] }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Privacy Filtered",
      "description": "Documents processed through MedDeID PII redaction pipeline in the selected time range.",
      "gridPos": { "x": 12, "y": 5, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(dpi_documents_processed_total{service=\"privacy_filter\"}[$__range]))", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#38A169", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#38A169" }] }
        }
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Forensic Analyses",
      "description": "Forgery detection analyses completed in the selected time range.",
      "gridPos": { "x": 18, "y": 5, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(dpi_documents_processed_total{service=\"forgensic\"}[$__range]))", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#DD6B20", "mode": "fixed" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#DD6B20" }] }
        }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "━━━━━━  PLATFORM VITALS  ━━━━━━",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Docs Today",
      "description": "Total documents processed across all services in the selected time range.",
      "gridPos": { "x": 0, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(dpi_documents_processed_total[$__range]))", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#4299E1", "mode": "fixed" },
          "unit": "short"
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Processing Now",
      "description": "Documents currently in worker queues waiting to be processed.",
      "gridPos": { "x": 4, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(dpi_queue_depth)", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }, { "value": 5, "color": "#FFA500" }, { "value": 20, "color": "#E53E3E" }] },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Error Rate",
      "description": "5xx HTTP error rate across all DPI services in the last hour. Target: < 1%.",
      "gridPos": { "x": 8, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(dpi_http_requests_total{status_code=~\"5..\"}[1h])) / sum(rate(dpi_http_requests_total[1h])) * 100 or vector(0)", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }, { "value": 1, "color": "#FFA500" }, { "value": 5, "color": "#E53E3E" }] },
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 2
        }
      }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Queue Total",
      "description": "Total documents queued across all three worker pipelines (ABDM + NHCX + Forgensic).",
      "gridPos": { "x": 12, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(dpi_queue_depth)", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }, { "value": 10, "color": "#FFA500" }, { "value": 50, "color": "#E53E3E" }] },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      }
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Platform Uptime",
      "description": "Average service availability across all 5 DPI services over the last 24 hours. SLA target: ≥ 99%.",
      "gridPos": { "x": 16, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "avg(avg_over_time(up{job=~\"pdf2abdm|pdf2nhcx|privacy_filter|forgensic|session_logger\"}[24h])) * 100", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#E53E3E" }, { "value": 95, "color": "#FFA500" }, { "value": 99, "color": "#3CB371" }] },
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 2
        }
      }
    },
    {
      "id": 26,
      "type": "stat",
      "title": "Active Alerts",
      "description": "Number of alert rules currently in firing state. 0 = all clear.",
      "gridPos": { "x": 20, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "legendFormat": "", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }, { "value": 1, "color": "#FFA500" }, { "value": 3, "color": "#E53E3E" }] },
          "color": { "mode": "thresholds" },
          "unit": "short",
          "links": [{ "title": "View Alerts", "url": "/d/tanuh-alerts-incidents", "targetBlank": false }]
        }
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "━━━━━━  SERVICE HEALTH  ━━━━━━",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "type": "stat",
      "title": "pdf2abdm",
      "description": "ABDM Clinical Record Extraction API. Click to open Service Operations for this service.",
      "gridPos": { "x": 0, "y": 15, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"pdf2abdm\"}", "legendFormat": "Status", "refId": "A" },
        { "expr": "sum(rate(dpi_http_requests_total{service=\"pdf2abdm\"}[$interval]))", "legendFormat": "Req/s", "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum(rate(dpi_http_request_duration_seconds_bucket{service=\"pdf2abdm\"}[$interval])) by (le))", "legendFormat": "P95 Latency", "refId": "C" },
        { "expr": "sum(increase(dpi_http_requests_total{service=\"pdf2abdm\",status_code=~\"5..\"}[1h])) or vector(0)", "legendFormat": "5xx Errors", "refId": "D" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "vertical",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#E53E3E" }, "1": { "text": "UP", "color": "#3CB371" } } }] }, { "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "#E53E3E" }, { "value": 1, "color": "#3CB371" }] } }] },
          { "matcher": { "id": "byName", "options": "Req/s" }, "properties": [{ "id": "unit", "value": "reqps" }, { "id": "color", "value": { "fixedColor": "#4299E1", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95 Latency" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "color", "value": { "fixedColor": "#718096", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx Errors" }, "properties": [{ "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }, { "value": 1, "color": "#E53E3E" }] } }] }
        ]
      },
      "links": [{ "title": "Investigate Service", "url": "/d/tanuh-service-ops?var-service=pdf2abdm", "targetBlank": false }]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "pdf2nhcx",
      "description": "NHCX Insurance Policy Extraction API. Click to open Service Operations for this service.",
      "gridPos": { "x": 5, "y": 15, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"pdf2nhcx\"}", "legendFormat": "Status", "refId": "A" },
        { "expr": "sum(rate(dpi_http_requests_total{service=\"pdf2nhcx\"}[$interval]))", "legendFormat": "Req/s", "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum(rate(dpi_http_request_duration_seconds_bucket{service=\"pdf2nhcx\"}[$interval])) by (le))", "legendFormat": "P95 Latency", "refId": "C" },
        { "expr": "sum(increase(dpi_http_requests_total{service=\"pdf2nhcx\",status_code=~\"5..\"}[1h])) or vector(0)", "legendFormat": "5xx Errors", "refId": "D" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "vertical",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#E53E3E" }, "1": { "text": "UP", "color": "#3CB371" } } }] }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "#E53E3E" }, { "value": 1, "color": "#3CB371" }] } }] },
          { "matcher": { "id": "byName", "options": "Req/s" }, "properties": [{ "id": "unit", "value": "reqps" }, { "id": "color", "value": { "fixedColor": "#805AD5", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95 Latency" }, "properties": [{ "id": "unit", "value": "s" }] },
          { "matcher": { "id": "byName", "options": "5xx Errors" }, "properties": [{ "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "#3CB371" }, { "value": 1, "color": "#E53E3E" }] } }] }
        ]
      },
      "links": [{ "title": "Investigate Service", "url": "/d/tanuh-service-ops?var-service=pdf2nhcx", "targetBlank": false }]
    },
    {
      "id": 33,
      "type": "stat",
      "title": "privacy_filter",
      "description": "MedDeID PII Redaction API. Click to open Service Operations for this service.",
      "gridPos": { "x": 10, "y": 15, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"privacy_filter\"}", "legendFormat": "Status", "refId": "A" },
        { "expr": "sum(rate(dpi_http_requests_total{service=\"privacy_filter\"}[$interval]))", "legendFormat": "Req/s", "refId": "B" },
